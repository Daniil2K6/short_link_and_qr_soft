# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shortlink_qr
DB_USER=postgres
DB_PASSWORD=password

# Server Configuration
SERVER_PORT=3000
NODE_ENV=development

# Frontend URL for CORS
