# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Short code length
SHORT_CODE_LENGTH=7

# Rate limiting
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=10
